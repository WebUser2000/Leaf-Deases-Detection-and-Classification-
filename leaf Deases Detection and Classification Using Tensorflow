        "id": "i3Dkh798DT3K"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "data_augmentation = tf.keras.Sequential([\n",
        "\n",
        "    layers.RandomFlip(\"horizontal_and_vertical\"),\n",
        "\n",
        "    layers.RandomRotation(0.2),\n",
        "\n",
        "    layers.RandomZoom(0.2),\n",
        "\n",
        "    layers.RandomContrast(0.2)\n",
        "\n",
        "])"
