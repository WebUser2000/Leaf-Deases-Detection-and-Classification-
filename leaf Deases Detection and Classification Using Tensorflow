        "    ),\n",
        "\n",
        "    layers.MaxPooling2D(),\n",
        "\n",
        "    # CNN BLOCK 3\n",
        "    layers.Conv2D(\n",
        "        128,\n",
        "        (3,3),\n",
        "        activation='relu',\n",
        "        padding='same'\n",
        "    ),\n",
        "\n",
        "    layers.MaxPooling2D(),\n",
        "\n",
        "    # Dropout\n",
        "    layers.Dropout(0.2),\n",
        "\n",
        "    # Flatten\n",
        "    layers.Flatten(),\n",
        "\n",
        "    # Dense Layer\n",
